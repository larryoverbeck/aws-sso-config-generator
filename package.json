    "ini": "^5.0.0"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/node": "^22.15.0",
    "fast-check": "^4.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
