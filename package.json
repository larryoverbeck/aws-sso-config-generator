{
  "name": "aws-sso-config-gen",
  "version": "1.0.0",
  "description": "CLI tool to generate AWS CLI config profiles from SSO account discovery",
  "type": "module",
  "bin": {
    "aws-sso-config-gen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest --run",
    "test:watch": "vitest"
